generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Event {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  adminId   String?
  code      String?   @unique
  admin     Admin?    @relation(fields: [adminId], references: [id])
  guests    Guest[]
  Message   Message[]
}

model Guest {
  id                     String   @id @default(cuid())
  eventId                String
  name                   String
  email                  String?
  phone                  String?
  hasDietRestriction     Boolean  @default(false)
  dietRestrictionComment String?
  rsvp                   Boolean  @default(true)
  isMainGuest            Boolean  @default(false)
  comments               String?
  createdAt              DateTime @default(now())
  plusOne                Boolean  @default(false)
  goesWith               String?
  mesa                   Int?
  nroPulsera             Int?
  event                  Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events    Event[]
}

model Message {
  id        String   @id
  eventId   String
  createdAt DateTime @default(now())
  message   String
  from      String
  Event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}
