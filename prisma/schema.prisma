generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Event {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  adminId   String?
  code      String?   @unique
  admin     Admin?    @relation(fields: [adminId], references: [id])
  guests    Guest[]
  Message   Message[]
}

model Guest {
  id                     String   @id @default(cuid())
  eventId                String
  name                   String
  email                  String?
  phone                  String?
  hasDietRestriction     Boolean  @default(false)
  dietRestrictionComment String?
  rsvp                   Boolean  @default(true)
  isMainGuest            Boolean  @default(false)
  comments               String?
  createdAt              DateTime @default(now())
  plusOne                Boolean  @default(false)
  goesWith               String?
  mesa                   Int?
  nroPulsera             Int?
  event                  Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events    Event[]
}

model Message {
  id        String   @id
  eventId   String
  createdAt DateTime @default(now())
  message   String
  from      String
  Event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model AndroLedGuest {
  id                     String       @id @default(cuid())
  name                   String
  email                  String?
  phone                  String?
  hasDietRestriction     Boolean      @default(false)
  dietRestrictionComment String?
  rsvp                   Boolean      @default(true)
  isMainGuest            Boolean      @default(false)
  comments               String?
  createdAt              DateTime     @default(now())
  plusOne                Boolean      @default(false)
  goesWith               String?
  mesa                   Int?
  nroPulsera             Int?
  pulseraEntregada       Boolean      @default(false)
  avatar                 String?
  figus                  FigusAlbum?
}

model FigusAlbum {
  id        String        @id @default(cuid())
  guestId   String        @unique
  counts    Json          @default("{}")
  packsLeft String[]      @default(["start"])
  guest     AndroLedGuest @relation(fields: [guestId], references: [id], onDelete: Cascade)
  updatedAt DateTime      @updatedAt
}

model FigusTrivia {
  id              String    @id @default(cuid())
  eventId         String
  question        String
  options         String[]
  answer          Int
  active          Boolean   @default(false)
  activeAt        DateTime?
  durationSeconds Int?
  createdAt       DateTime  @default(now())
}

model FigusCodigo {
  id              String    @id @default(cuid())
  eventId         String
  code            String
  active          Boolean   @default(false)
  activeAt        DateTime?
  durationSeconds Int?
  usedBy          String[]  @default([])
  createdAt       DateTime  @default(now())
}

model FigusCardStock {
  id       String @id @default(cuid())
  eventId  String
  cardId   Int
  maxCount Int    @default(10)
  issued   Int    @default(0)

  @@unique([eventId, cardId])
}